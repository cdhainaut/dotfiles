{
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "opencode-go": {
      "name": "OpenCode Go",
      "options": {}
    },
    "openai": {
      "name": "OpenAI",
      "options": {}
    }
  },
  "model": "opencode-go/deepseek-v4-pro",
  "small_model": "opencode-go/deepseek-v4-pro",
  "agent": {
    "review": {
      "mode": "primary",
      "description": "Review scientifique: Kimi K2.6. Tool calling validé opencode, bon rapport qualité/coût.",
      "model": "opencode-go/kimi-k2.6",
      "temperature": 0.05,
      "reasoningEffort": "high",
      "textVerbosity": "low",
      "steps": 15,
      "permission": {
        "edit": "deny",
        "bash": {
          "*": "ask",
          "python test_*.py": "allow",
          "pytest --coverage": "allow"
        },
        "webfetch": "ask"
      }
    },
    "gpt": {
      "mode": "primary",
      "description": "Review premium: GPT-5.4 via OpenAI (ChatGPT Plus). Rigueur maximale.",
      "model": "openai/gpt-5.4",
      "temperature": 0.05,
      "reasoningEffort": "high",
      "textVerbosity": "low",
      "reasoningSummary": "auto",
      "steps": 15,
      "permission": {
        "edit": "deny",
        "bash": {
          "*": "ask",
          "python test_*.py": "allow",
          "pytest --coverage": "allow"
        },
        "webfetch": "ask"
      }
    }
  }
}
