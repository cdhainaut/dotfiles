{
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "opencode-go": {
      "name": "OpenCode Go",
      "options": {}
    },
    "deepseek": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "DeepSeek",
      "options": {
        "baseURL": "https://api.deepseek.com/v1",
        "apiKey": "{env:DEEPSEEK_API_KEY}"
      },
      "models": {
        "deepseek-chat": {
          "name": "DeepSeek Chat (V3)"
        },
        "deepseek-reasoner": {
          "name": "DeepSeek Reasoner (R1)"
        }
      }
    },
    "openai": {
      "name": "OpenAI",
      "options": {},
      "models": {
        "gpt-5.4": {
          "name": "GPT-5.4",
          "variants": {
            "science": {
              "reasoningEffort": "high",
              "textVerbosity": "low",
              "reasoningSummary": "auto"
            }
          }
        },
        "gpt-5.4-mini": {
          "name": "GPT-5.4 Mini",
          "variants": {
            "lean": {
              "reasoningEffort": "low",
              "textVerbosity": "low"
            }
          }
        },
        "gpt-5.4-mini-fast": {
          "name": "GPT-5.4 Mini Fast",
          "variants": {
            "lean": {
              "reasoningEffort": "none",
              "textVerbosity": "low"
            }
          }
        }
      }
    }
  },
  "model": "deepseek/deepseek-chat",
  "small_model": "opencode/minimax-m2.5-free",
  "agent": {
    "build": {
      "mode": "primary",
      "description": "Build agent with DeepSeek Chat: strong quality/cost for daily coding.",
      "model": "deepseek/deepseek-chat",
      "temperature": 0.1,
      "reasoningEffort": "medium",
      "textVerbosity": "low",
      "steps": 18,
      "permission": {
        "webfetch": "deny"
      }
    },
    "plan": {
      "mode": "primary",
      "description": "Scientific planning agent: high-grade reasoning, read-only.",
      "model": "openai/gpt-5.4",
      "temperature": 0.1,
      "reasoningEffort": "high",
      "textVerbosity": "low",
      "reasoningSummary": "auto",
      "steps": 8,
      "permission": {
        "edit": "deny",
        "bash": "ask",
        "webfetch": "ask"
      }
    },
    "cheap-explore": {
      "mode": "subagent",
      "description": "Cheap exploration: search and summarize with minimal cost.",
      "model": "openai/gpt-5.4-mini-fast",
      "temperature": 0,
      "reasoningEffort": "none",
      "textVerbosity": "low",
      "steps": 4,
      "permission": {
        "edit": "deny",
        "bash": "deny",
        "webfetch": "deny"
      }
    },
    "science-review": {
      "mode": "subagent",
      "description": "Scientific reviewer: checks units, assumptions, numerics, stability.",
      "model": "openai/gpt-5.4",
      "temperature": 0.1,
      "reasoningEffort": "high",
      "textVerbosity": "low",
      "reasoningSummary": "auto",
      "steps": 5,
      "permission": {
        "edit": "deny",
        "bash": "deny",
        "webfetch": "ask"
      }
    }
  }
}
