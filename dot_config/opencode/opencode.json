{
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "opencode-go": {
      "name": "OpenCode Go",
      "options": {}
    },
    "deepseek": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "DeepSeek",
      "options": {
        "baseURL": "https://api.deepseek.com/v1",
        "apiKey": "{env:DEEPSEEK_API_KEY}"
      },
      "models": {
        "deepseek-chat": {
          "name": "DeepSeek Chat (V3)"
        },
        "deepseek-reasoner": {
          "name": "DeepSeek Reasoner (R1)"
        }
      }
    },
    "openai": {
      "name": "OpenAI",
      "options": {},
      "models": {
        "gpt-5.4": {
          "name": "GPT-5.4",
          "variants": {
            "science": {
              "reasoningEffort": "high",
              "textVerbosity": "low",
              "reasoningSummary": "auto"
            }
          }
        },
        "gpt-5.4-mini": {
          "name": "GPT-5.4 Mini",
          "variants": {
            "lean": {
              "reasoningEffort": "low",
              "textVerbosity": "low"
            }
          }
        },
        "gpt-5.4-mini-fast": {
          "name": "GPT-5.4 Mini Fast",
          "variants": {
            "lean": {
              "reasoningEffort": "none",
              "textVerbosity": "low"
            }
          }
        }
      }
    }
  },
  "model": "deepseek/deepseek-chat",
  "small_model": "opencode/minimax-m2.5-free",
  "agent": {
    "build": {
      "mode": "primary",
      "description": "Build agent: DeepSeek V3 for high-volume daily coding.",
      "model": "deepseek/deepseek-chat",
      "temperature": 0.1,
      "textVerbosity": "low",
      "steps": 20,
      "permission": {
        "webfetch": "ask"
      }
    },
    "plan": {
      "mode": "primary",
      "description": "Scientific planning agent: DeepSeek R1 high reasoning.",
      "model": "deepseek/deepseek-reasoner",
      "temperature": 0.1,
      "reasoningEffort": "high",
      "textVerbosity": "low",
      "steps": 12,
      "permission": {
        "edit": "deny",
        "bash": "ask",
        "webfetch": "ask"
      }
    },
    "science-review": {
      "mode": "primary",
      "description": "Scientific review agent: GPT-5.4 for critical validation.",
      "model": "openai/gpt-5.4",
      "temperature": 0.05,
      "reasoningEffort": "high",
      "textVerbosity": "low",
      "reasoningSummary": "auto",
      "steps": 15,
      "permission": {
        "edit": "deny",
        "bash": {
          "*": "ask",
          "python test_*.py": "allow",
          "pytest --coverage": "allow"
        },
        "webfetch": "ask"
      }
    }
  }
}
