{
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "opencode-go": {
      "name": "OpenCode Go",
      "options": {}
    },
    "github-copilot": {
      "name": "GitHub Copilot",
      "options": {}
    }
  },
  "model": "opencode-go/deepseek-v4-pro",
  "small_model": "opencode-go/deepseek-v4-pro",
  "agent": {
    "deepseek": {
      "mode": "primary",
      "description": "Coding scientifique: DeepSeek V4 Pro (3.4K req/5h, reasoning high, contexte 1M). Compacter Ctrl+X C pour réduire le cache. F2 pour Flash sur tâches simples.",
      "model": "opencode-go/deepseek-v4-pro",
      "reasoningEffort": "high",
      "textVerbosity": "low",
      "steps": 20,
      "permission": {
        "webfetch": "ask"
      }
    },
    "review": {
      "mode": "primary",
      "description": "Review critique: GPT-5.4 via Copilot. Rigueur inégalée, gratuit avec ton abonnement GitHub.",
      "model": "github-copilot/gpt-5.4",
      "temperature": 0.05,
      "reasoningEffort": "high",
      "textVerbosity": "low",
      "reasoningSummary": "auto",
      "steps": 15,
      "permission": {
        "edit": "deny",
        "bash": {
          "*": "ask",
          "python test_*.py": "allow",
          "pytest --coverage": "allow"
        },
        "webfetch": "ask"
      }
    }
  }
}
