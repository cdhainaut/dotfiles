{
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "opencode-go": {
      "name": "OpenCode Go",
      "options": {}
    }
  },
  "model": "opencode-go/deepseek-v4-flash",
  "small_model": "opencode-go/deepseek-v4-flash",
  "agent": {
    "deepseek": {
      "mode": "primary",
      "description": "Agent unique: DeepSeek V4 Flash par défaut (31K req/5h, pas de reasoning, 1M ctx). F2 pour cycler vers DeepSeek V4 Pro si besoin de reasoning.",
      "model": "opencode-go/deepseek-v4-flash",
      "temperature": 0.1,
      "textVerbosity": "low",
      "steps": 20,
      "permission": {
        "webfetch": "ask",
        "todowrite": "allow"
      }
    },
    "review": {
      "mode": "primary",
      "description": "Review critique: Kimi K2.6. Tool calling validé opencode, rigueur scientifique.",
      "model": "opencode-go/kimi-k2.6",
      "temperature": 0.05,
      "reasoningEffort": "high",
      "textVerbosity": "low",
      "steps": 15,
      "permission": {
        "edit": "deny",
        "bash": {
          "*": "ask",
          "python test_*.py": "allow",
          "pytest --coverage": "allow"
        },
        "webfetch": "ask"
      }
    }
  }
}
