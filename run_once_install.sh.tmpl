#!/usr/bin/env bash
set -euo pipefail

# Options
: "${HEADLESS:=0}"   # HEADLESS=1 pour skipper les app GUI (wezterm)
export DEBIAN_FRONTEND=noninteractive
: "${TZ:=Europe/Paris}"    # force la timezone (override possible à l'env)

log() { printf "\n\033[1;36m%s\033[0m\n" "👉 $*"; }
ok()  { printf "\033[1;32m%s\033[0m\n" "✅ $*"; }
skip(){ printf "\033[0;33m%s\033[0m\n"  "⏭️  $*"; }
need_cmd() { command -v "$1" >/dev/null 2>&1; }
in_docker() { [ -f /.dockerenv ] || grep -qa 'container=docker' /proc/1/environ 2>/dev/null; }

# sudo peut être absent en conteneur minimaliste
SUDO="sudo"
need_cmd sudo || SUDO=""


log "Mise à jour du système + préconfiguration tzdata ($TZ)"
$SUDO apt-get update -y
# préconfigure tzdata pour éviter les prompts
echo "$TZ" | $SUDO tee /etc/timezone >/dev/null || true
$SUDO ln -sf "/usr/share/zoneinfo/$TZ" /etc/localtime || true
$SUDO apt-get install -y tzdata >/dev/null 2>&1 || true
$SUDO dpkg-reconfigure -f noninteractive tzdata >/dev/null 2>&1 || true

$SUDO apt-get upgrade -y

log "Paquets de base"
$SUDO apt-get install -y \
  build-essential curl git unzip ca-certificates pkg-config cmake ninja-build gettext \
  zsh ripgrep fzf fd-find bat eza plank wmctrl

# Ubuntu: fd -> fdfind, bat -> batcat
if ! need_cmd fd && [ -x /usr/bin/fdfind ]; then
  $SUDO ln -sf /usr/bin/fdfind /usr/local/bin/fd
fi
if ! need_cmd bat && [ -x /usr/bin/batcat ]; then
  $SUDO ln -sf /usr/bin/batcat /usr/local/bin/bat
fi

### 1. Zsh + Oh My Zsh
if ! need_cmd zsh; then
  log "Installation de zsh"
  $SUDO apt-get install -y zsh
else
  ok "zsh déjà installé"
fi

if [ ! -d "$HOME/.oh-my-zsh" ]; then
  log "Installation de Oh My Zsh (unattended)"
  RUNZSH=no CHSH=no KEEP_ZSHRC=yes \
  sh -c "$(curl -fsSL https://raw.githubusercontent.com/ohmyzsh/ohmyzsh/master/tools/install.sh)" "" --unattended
else
  ok "Oh My Zsh déjà installé"
fi

# Définir zsh comme shell par défaut si nécessaire (skip en conteneur)
if [ "${SHELL:-}" != "$(command -v zsh)" ]; then
  if in_docker; then
    skip "En conteneur: on ne change pas le shell (chsh demande un mot de passe/PAM)"
  else
    log "chsh vers zsh"
    chsh -s "$(command -v zsh)" || skip "Impossible de changer le shell (droits/PAM)"
  fi
else
  ok "zsh déjà shell par défaut"
fi

### Neovim (branche stable)
if ! need_cmd nvim; then
  log "Installation de Neovim depuis les sources (branche stable)"
  rm -rf /tmp/neovim
  git clone --branch stable --depth 1 https://github.com/neovim/neovim.git /tmp/neovim
  ( cd /tmp/neovim && make CMAKE_BUILD_TYPE=Release && $SUDO make install )
  ok "Neovim installé"
else
  ok "Neovim déjà installé"
fi

### 3. Rust & Cargo (pré-requis pour zellij/helix/wezterm-build)
if ! need_cmd cargo; then
  log "Installation de Rust (rustup)"
  curl -fsSL https://sh.rustup.rs | sh -s -- -y --no-modify-path
  # shellcheck disable=SC1091
  source "$HOME/.cargo/env"
else
  ok "Rust/Cargo déjà installés"
fi

### 4. zellij via cargo (plus frais que les paquets)
if ! need_cmd zellij; then
  log "Installation de zellij (cargo)"
  cargo install --locked zellij
else
  ok "zellij déjà installé"
fi

### helix-assist (AI code completion, prebuilt binary)
if ! command -v helix-assist &>/dev/null; then
  log "Installation de helix-assist"
  curl -fsSL "https://github.com/leona/helix-assist/releases/latest/download/helix-assist-linux-amd64" -o /tmp/helix-assist
  install -m 755 /tmp/helix-assist "$HOME/.local/bin/helix-assist"
  ok "helix-assist"
fi

### 5. Helix depuis la source (runtime inclus)
if ! need_cmd hx; then
  log "Installation de Helix (source)"
  rm -rf /tmp/helix
  git clone --branch 25.07.1 --depth 1 https://github.com/helix-editor/helix.git /tmp/helix
  ( 
    cd /tmp/helix
    # méthode recommandée: build puis install binaire + runtime
    cargo install --path helix-term --locked
    $SUDO mkdir -p /usr/local/share/helix
    $SUDO rm -rf /usr/local/share/helix/runtime
    $SUDO cp -r runtime /usr/local/share/helix/
  )
  ok "Helix installé"
else
  ok "Helix déjà installé"
fi

### 6. Lazygit (prebuilt binary)
if ! need_cmd lazygit; then
  log "Installation de lazygit"
  LAZYGIT_VERSION=$(curl -fsSL "https://api.github.com/repos/jesseduffield/lazygit/releases/latest" | grep -Po '"tag_name": "v\K[^"]*')
  curl -fsSL "https://github.com/jesseduffield/lazygit/releases/download/v${LAZYGIT_VERSION}/lazygit_${LAZYGIT_VERSION}_Linux_x86_64.tar.gz" | tar xzf - -C /tmp lazygit
  $SUDO install /tmp/lazygit /usr/local/bin/lazygit
  ok "lazygit $LAZYGIT_VERSION installé"
else
  ok "lazygit déjà installé"
fi

### 7. Lazydocker (prebuilt binary)
if ! need_cmd lazydocker; then
  log "Installation de lazydocker"
  LAZYDOCKER_VERSION=$(curl -fsSL "https://api.github.com/repos/jesseduffield/lazydocker/releases/latest" | grep -Po '"tag_name": "v\K[^"]*')
  curl -fsSL "https://github.com/jesseduffield/lazydocker/releases/download/v${LAZYDOCKER_VERSION}/lazydocker_${LAZYDOCKER_VERSION}_Linux_x86_64.tar.gz" | tar xzf - -C /tmp lazydocker
  $SUDO install /tmp/lazydocker /usr/local/bin/lazydocker
  ok "lazydocker $LAZYDOCKER_VERSION installé"
else
  ok "lazydocker déjà installé"
fi

### shfmt (shell formatter)
if ! command -v shfmt &>/dev/null; then
  log "Installation de shfmt"
  SHFMT_VERSION=$(curl -fsSL "https://api.github.com/repos/mvdan/sh/releases/latest" | grep -Po '"tag_name": "v\K[^"]*')
  curl -fsSL "https://github.com/mvdan/sh/releases/download/v${SHFMT_VERSION}/shfmt_v${SHFMT_VERSION}_linux_amd64" -o /tmp/shfmt
  install -m 755 /tmp/shfmt "$HOME/.local/bin/shfmt"
  ok "shfmt $SHFMT_VERSION"
fi

### yamlfmt (YAML formatter)
if ! command -v yamlfmt &>/dev/null; then
  log "Installation de yamlfmt"
  YAMLFMT_VERSION=$(curl -fsSL "https://api.github.com/repos/google/yamlfmt/releases/latest" | grep -Po '"tag_name": "v\K[^"]*')
  curl -fsSL "https://github.com/google/yamlfmt/releases/download/v${YAMLFMT_VERSION}/yamlfmt_${YAMLFMT_VERSION}_linux_amd64.tar.gz" | tar xzf - -C /tmp yamlfmt
  install -m 755 /tmp/yamlfmt "$HOME/.local/bin/yamlfmt"
  ok "yamlfmt $YAMLFMT_VERSION"
fi

### 8. Yazi (prebuilt binary)
if ! need_cmd yazi; then
  log "Installation de yazi"
  YAZI_VERSION=$(curl -fsSL "https://api.github.com/repos/sxyazi/yazi/releases/latest" | grep -Po '"tag_name": "v\K[^"]*')
  curl -fsSL "https://github.com/sxyazi/yazi/releases/download/v${YAZI_VERSION}/yazi-x86_64-unknown-linux-gnu.zip" -o /tmp/yazi.zip
  unzip -o /tmp/yazi.zip -d /tmp/yazi-bin
  $SUDO install /tmp/yazi-bin/yazi-x86_64-unknown-linux-gnu/yazi /usr/local/bin/yazi
  ok "yazi $YAZI_VERSION installé"
else
  ok "yazi déjà installé"
fi

### WezTerm (optionnel, skip en headless)
if [ "$HEADLESS" = "1" ]; then
  skip "HEADLESS=1 → on skip WezTerm"
else
  if ! need_cmd wezterm; then
    log "Installation de WezTerm (paquet .deb officiel)"
    # ⚠️ WezTerm est GUI, utile uniquement sur machine desktop.
    # Méthode générique via .deb (peut nécessiter ajustement de version):
    tmpd=$(mktemp -d)
    cd "$tmpd"
    # Astuce: récupère la dernière version stable via GitHub API si tu préfères.
    # Ici on montre un placeholder. Remplace $DEB_URL par l’URL exacte de la release.
    DEB_URL=""
    if [ -n "$DEB_URL" ]; then
      curl -fsSL "$DEB_URL" -o wezterm.deb
      $SUDO apt-get install -y ./wezterm.deb || $SUDO dpkg -i ./wezterm.deb || true
      $SUDO apt-get -f install -y
    else
      skip "Pas d'URL de release WezTerm renseignée — à compléter."
    fi
  else
    ok "WezTerm déjà installé"
  fi
fi

### Miniconda (zsh init)
if ! need_cmd conda; then
  log "Installation de Miniconda"
  curl -fsSL https://repo.anaconda.com/miniconda/Miniconda3-latest-Linux-x86_64.sh -o /tmp/miniconda.sh
  bash /tmp/miniconda.sh -b -p "$HOME/miniconda"

  # Initialise pour zsh (persistant)
  "$HOME/miniconda/bin/conda" init zsh || true

  # 👉 Rendez conda utilisable **dans cette session bash** (immédiat, non-persistant)
  if [ -n "${BASH_VERSION:-}" ] && [ -x "$HOME/miniconda/bin/conda" ]; then
    eval "$("$HOME/miniconda/bin/conda" shell.bash hook)"
  elif [ -f "$HOME/miniconda/etc/profile.d/conda.sh" ]; then
    # fallback générique si conda hook indisponible
    # shellcheck disable=SC1091
    . "$HOME/miniconda/etc/profile.d/conda.sh"
  else
    export PATH="$HOME/miniconda/bin:$PATH"
  fi

  ok "Miniconda installé"
else
  ok "Miniconda déjà installé"
fi

### Python LSPs
log "Installation de pyright et ruff"
pip install --quiet pyright ruff
ok "pyright + ruff"

### Node.js (via nvm) + Claude Code
if ! need_cmd claude; then
  if ! need_cmd npm; then
    log "Installation de Node.js (nvm)"
    curl -fsSL https://raw.githubusercontent.com/nvm-sh/nvm/v0.40.3/install.sh | bash
    export NVM_DIR="$HOME/.nvm"
    [ -s "$NVM_DIR/nvm.sh" ] && . "$NVM_DIR/nvm.sh"
    nvm install --lts
    ok "Node.js $(node --version) installé"
  fi
  log "Installation de Claude Code"
  npm install -g @anthropic-ai/claude-code
  ok "Claude Code installé"
else
  ok "Claude Code déjà installé"
fi

### GitHub CLI
if ! need_cmd gh; then
  log "Installation de GitHub CLI"
  curl -fsSL https://cli.github.com/packages/githubcli-archive-keyring.gpg | $SUDO dd of=/usr/share/keyrings/githubcli-archive-keyring.gpg 2>/dev/null
  echo "deb [arch=$(dpkg --print-architecture) signed-by=/usr/share/keyrings/githubcli-archive-keyring.gpg] https://cli.github.com/packages stable main" | $SUDO tee /etc/apt/sources.list.d/github-cli.list >/dev/null
  $SUDO apt-get update -y >/dev/null 2>&1
  $SUDO apt-get install -y gh >/dev/null 2>&1
  ok "GitHub CLI installé"
else
  ok "GitHub CLI déjà installé"
fi

log "Vérification versions"
ver() { printf '   - %s: %s\n' "$1" "${2:-}"; }

ver "zsh" "$(zsh --version 2>/dev/null || true)"
ver "oh-my-zsh" "$(test -d "$HOME/.oh-my-zsh" && echo present || echo absent)"
ver "nvim" "$(nvim --version 2>/dev/null | head -n1 || true)"
ver "rustc" "$(rustc --version 2>/dev/null || true)"
ver "cargo" "$(cargo --version 2>/dev/null || true)"
ver "zellij" "$(zellij --version 2>/dev/null || true)"
ver "hx" "$(hx --version 2>/dev/null || true)"
ver "fzf" "$(fzf --version 2>/dev/null || true)"
ver "fd" "$(fd --version 2>/dev/null || fdfind --version 2>/dev/null || true)"
ver "bat" "$(bat --version 2>/dev/null || batcat --version 2>/dev/null || true)"
ver "ripgrep" "$(rg --version 2>/dev/null | head -n1 || true)"
ver "lazygit" "$(lazygit --version 2>/dev/null | head -n1 || true)"
ver "lazydocker" "$(lazydocker --version 2>/dev/null || true)"
ver "yazi" "$(yazi --version 2>/dev/null || true)"
ver "plank" "$(plank --version 2>/dev/null || echo 'installed')"
ver "pyright" "$(pyright --version 2>/dev/null || echo 'not found')"
ver "ruff" "$(ruff --version 2>/dev/null || echo 'not found')"
ver "shfmt" "$(shfmt --version 2>/dev/null || echo 'not found')"
ver "yamlfmt" "$(yamlfmt --version 2>/dev/null || echo 'not found')"
ver "claude" "$(claude --version 2>/dev/null || true)"
ver "gh" "$(gh --version 2>/dev/null | head -n1 || true)"

if need_cmd wezterm; then
  ver "wezterm" "$(wezterm --version 2>/dev/null || true)"
else
  ver "wezterm" "skipped/headless"
fi

if need_cmd conda; then
  ver "conda" "$(conda --version 2>/dev/null || true)"
else
  ver "conda" "not in PATH (see Miniconda step)"
fi

ok "Stack de développement installée avec succès 🎉"
