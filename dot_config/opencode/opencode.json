{
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "opencode-go": {
      "name": "OpenCode Go",
      "options": {}
    }
  },
  "model": "opencode-go/deepseek-v4-pro",
  "small_model": "opencode-go/deepseek-v4-pro",
  "agent": {
    "deepseek": {
      "mode": "primary",
      "description": "Coding quotidien: DeepSeek V4 Pro. Contexte 1M, LiveCodeBench #1 (93.5), Codeforces 3206, Apex Shortlist #1 (90.2).",
      "model": "opencode-go/deepseek-v4-pro",
      "temperature": 0.1,
      "reasoningEffort": "high",
      "textVerbosity": "low",
      "steps": 20,
      "permission": {
        "webfetch": "ask"
      }
    },
    "plan": {
      "mode": "primary",
      "description": "Planification: DeepSeek V4 Pro reasoning max. Papiers + codebase en 1M contexte.",
      "model": "opencode-go/deepseek-v4-pro",
      "temperature": 0.1,
      "reasoningEffort": "max",
      "textVerbosity": "low",
      "steps": 15,
      "permission": {
        "edit": "ask",
        "bash": "ask",
        "webfetch": "ask",
        "todowrite": "allow"
      }
    },
    "review": {
      "mode": "primary",
      "description": "Review critique: Kimi K2.6. Tool calling validé opencode, rigueur scientifique.",
      "model": "opencode-go/kimi-k2.6",
      "temperature": 0.05,
      "reasoningEffort": "high",
      "textVerbosity": "low",
      "steps": 15,
      "permission": {
        "edit": "deny",
        "bash": {
          "*": "ask",
          "python test_*.py": "allow",
          "pytest --coverage": "allow"
        },
        "webfetch": "ask"
      }
    }
  }
}
