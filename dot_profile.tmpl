# ~/.profile — sources modular shell config

# if running bash
if [ -n "$BASH_VERSION" ]; then
    if [ -f "$HOME/.bashrc" ]; then
	. "$HOME/.bashrc"
    fi
fi

[[ -e ~/.private_keys ]] && . ~/.private_keys

for f in ~/.shell/path.sh ~/.shell/fzf.sh ~/.shell/projects.sh ~/.shell/aliases.sh ~/.shell/tools.sh; do
  [[ -e "$f" ]] && . "$f"
done

# Cargo/Rust
. "$HOME/.cargo/env"
